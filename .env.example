PORT=3000
NODE_ENV=production
TZ=America/Mexico_City

CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=6
CHATWOOT_AI_AGENT_ID=12
CHATWOOT_ACCESS_TOKEN=COLOCA_AQUI_EL_TOKEN_DE_AXEL_IA

OPENAI_API_KEY=COLOCA_AQUI_TU_API_KEY
OPENAI_MODEL=gpt-5-mini

AI_TIMEZONE=America/Mexico_City
AI_START_HOUR=7
AI_END_HOUR=22
AI_MAX_HISTORY_MESSAGES=25
AI_RESPONSE_DELAY_SECONDS=4
AI_MAX_REPLY_CHARS=1200

AI_ASSIGNED_LABEL=asignado
AI_UNATTENDED_LABEL=sin_atender
AI_VALIDATION_LABEL=validacion

# Clave opcional para impedir llamadas ajenas al webhook.
# Después se agrega como ?secret=... en la URL configurada en Chatwoot.
WEBHOOK_SECRET=CAMBIA_ESTA_CLAVE_LARGA
